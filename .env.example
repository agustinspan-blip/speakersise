# Canonical public URL of the deployed site, with no trailing slash.
# Read by `lib/site.ts`, used to:
#   - resolve relative OG image URLs in <meta property="og:image"> tags
#   - emit absolute URLs in /sitemap.xml
#   - set the Sitemap: and Host: lines in /robots.txt
#
# Local dev: leave it unset and the code falls back to http://localhost:3000.
# Vercel: set in Project Settings → Environment Variables for both
# Production AND Preview deployments (preview previews otherwise unfurl
# with the production OG image, which is misleading).
NEXT_PUBLIC_SITE_URL=https://truescale.app

# ── Contact form (Resend) ─────────────────────────────────────────────
# The /api/contact route relays form submissions through Resend. Until
# the three vars below are set in Vercel the endpoint returns 503 and
# the rest of the site keeps working.
#
# RESEND_API_KEY — server-only secret. Create at https://resend.com/api-keys.
RESEND_API_KEY=
#
# RESEND_TO — where contact messages land. Until the domain is set up in
# Cloudflare Email Routing, point this at the Gmail directly.
RESEND_TO=truescaleaudio@gmail.com
#
# RESEND_FROM — verified sender. Resend only allows arbitrary `From:`
# addresses once you've added & verified the sending domain in their
# dashboard. Before that, use their built-in test sender — but note
# `onboarding@resend.dev` can ONLY deliver to the Resend account
# owner's email (a sandbox guard, not a bug).
#   Sandbox:  "TrueScale <onboarding@resend.dev>"
#   Live:     "TrueScale <hello@truescaleaudio.com>"
RESEND_FROM=TrueScale <onboarding@resend.dev>
